## Example environment configuration

# When true the pipeline performs all validations and downloads but stops before loading into the database.
DRY_RUN_ONLY=true

# Enforce that all required source files must be found and successfully downloaded. If set to false the pipeline will
# proceed even if some files are missing, provided fallback URLs are defined.
STRICT_REQUIRED_FILES=true

# PostgreSQL connection settings
POSTGRES_DB=snies
POSTGRES_USER=snies
POSTGRES_PASSWORD=snies
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Base URL of the SNIES portal used to discover the dataset links
SNIES_BASE_URL=https://snies.mineducacion.gov.co/portal/ESTADISTICAS/Bases-consolidadas/
